---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import WorkoutCard from '~/components/WorkoutCard.astro';
import { WORKOUTS, CATEGORIES, GOALS, type Category, type Goal } from '~/data/workouts';

const metadata = {
  title: 'IRONPULSE — Premium Workout Plans for Every Level',
  description: 'Train smarter, get stronger, and transform your body with IRONPULSE. 12 premium workout plans across beginner, intermediate, and advanced levels.',
  ignoreTitleTemplate: true,
};

const stats = [
  { amount: '12', title: 'Workout Plans' },
  { amount: '60+', title: 'Exercises' },
  { amount: '3', title: 'Levels' },
  { amount: '4', title: 'Training Goals' },
];

const features = [
  {
    title: 'Structured Progression',
    description: 'Every plan is built with progressive overload — you always know what to lift next.',
    icon: 'tabler:trending-up',
  },
  {
    title: 'Every Muscle Group',
    description: 'Push, pull, legs, core, and conditioning — full coverage across all plans.',
    icon: 'tabler:body-scan',
  },
  {
    title: 'Built for Real Results',
    description: 'Programs designed by athletes, proven in the gym, ready for you to start today.',
    icon: 'tabler:award',
  },
  {
    title: 'Zero Guesswork',
    description: 'Sets, reps, rest, and notes for every exercise. Just follow the plan.',
    icon: 'tabler:list-check',
  },
];
---

<Layout metadata={metadata}>
  <!-- Hero Section ******************* -->

  <section class="relative md:-mt-[76px] not-prose overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1534438327275-aea6d88d1e4d?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80"
        alt="Athlete training"
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/80 to-neutral-950"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
      <div class="pt-0 md:pt-[76px] pointer-events-none"></div>
      <div class="py-20 md:py-32 lg:py-40">
        <div class="max-w-3xl">
          <p
            class="text-base text-red-500 font-bold tracking-widest uppercase intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
          >
            Train Harder. Get Stronger.
          </p>
          <h1
            class="mt-4 text-5xl md:text-7xl lg:text-8xl font-extrabold leading-none tracking-tighter text-white intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
          >
            FORGE YOUR<br />
            <span class="text-red-500">BEST BODY</span>
          </h1>
          <p
            class="mt-6 text-lg md:text-xl text-gray-300 max-w-xl intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
          >
            12 premium workout plans. Beginner to advanced. Muscle gain, fat loss, strength, and PPL. Your transformation starts now.
          </p>
          <div
            class="mt-10 flex flex-col sm:flex-row gap-4 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
          >
            <a
              href="#workouts"
              class="btn-primary font-semibold inline-flex items-center justify-center gap-2"
            >
              <Icon name="tabler:bolt" class="w-5 h-5" />
              Start Training
            </a>
            <a
              href="#about"
              class="btn inline-flex items-center justify-center gap-2 border-white/20 text-white hover:bg-white/10 hover:border-white/40"
            >
              Learn More
              <Icon name="tabler:arrow-right" class="w-5 h-5" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar ********************* -->

  <section class="bg-neutral-950 border-y border-white/5">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {
          stats.map((s) => (
            <div class="intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
              <div class="text-4xl md:text-5xl font-extrabold text-red-500 tracking-tight">{s.amount}</div>
              <div class="mt-1 text-sm font-semibold uppercase tracking-widest text-gray-500">{s.title}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Features ********************** -->

  <section id="about" class="relative scroll-mt-[72px]">
    <div class="max-w-7xl mx-auto px-4 md:px-6 py-16 md:py-24">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="text-red-500 font-bold tracking-widest uppercase text-sm">Why IRONPULSE</p>
        <h2 class="mt-2 text-3xl md:text-5xl font-extrabold tracking-tighter text-white">
          Programs that actually work
        </h2>
        <p class="mt-4 text-lg text-gray-400">
          No fluff. No gimmicks. Just structured training plans built to get you stronger, leaner, and bigger.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          features.map((f) => (
            <div class="rounded-2xl bg-neutral-900 border border-white/5 p-6 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade hover:border-red-600/30 transition">
              <div class="w-12 h-12 rounded-xl bg-red-600/10 flex items-center justify-center mb-4">
                <Icon name={f.icon} class="w-6 h-6 text-red-500" />
              </div>
              <h3 class="text-lg font-bold text-white">{f.title}</h3>
              <p class="mt-2 text-sm text-gray-400">{f.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Categories ********************* -->

  <section class="bg-neutral-950 border-y border-white/5">
    <div class="max-w-7xl mx-auto px-4 md:px-6 py-16 md:py-24">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="text-red-500 font-bold tracking-widest uppercase text-sm">Choose Your Level</p>
        <h2 class="mt-2 text-3xl md:text-5xl font-extrabold tracking-tighter text-white">Three paths. One goal.</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {
          (Object.keys(CATEGORIES) as Category[]).map((key, i) => {
            const cat = CATEGORIES[key];
            const count = WORKOUTS.filter((w) => w.category === key).length;
            return (
              <a
                id={cat.slug}
                href={`#workouts`}
                class="scroll-mt-[72px] group relative overflow-hidden rounded-2xl border border-white/5 hover:border-red-600/40 transition-all duration-300 hover:-translate-y-1 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
              >
                <div class:list={[
                  'absolute inset-0 bg-gradient-to-br',
                  key === 'beginner' && 'from-green-900/30 to-neutral-900',
                  key === 'intermediate' && 'from-amber-900/30 to-neutral-900',
                  key === 'advanced' && 'from-red-900/30 to-neutral-900',
                ]} />
                <div class="relative p-8 text-center">
                  <div class:list={[
                    'inline-flex w-16 h-16 rounded-full items-center justify-center text-2xl font-extrabold mb-4',
                    key === 'beginner' && 'bg-green-600 text-white',
                    key === 'intermediate' && 'bg-amber-500 text-white',
                    key === 'advanced' && 'bg-red-600 text-white',
                  ]}>
                    {i + 1}
                  </div>
                  <h3 class="text-2xl font-extrabold text-white">{cat.label}</h3>
                  <p class="mt-2 text-gray-400">{cat.description}</p>
                  <p class="mt-4 text-sm font-semibold text-red-500">{count} plans available</p>
                </div>
              </a>
            );
          })
        }
      </div>
    </div>
  </section>

  <!-- Workouts with Filters ********* -->

  <section id="workouts" class="relative scroll-mt-[72px]">
    <div class="max-w-7xl mx-auto px-4 md:px-6 py-16 md:py-24">
      <div class="text-center max-w-2xl mx-auto mb-10">
        <p class="text-red-500 font-bold tracking-widest uppercase text-sm">Workout Plans</p>
        <h2 class="mt-2 text-3xl md:text-5xl font-extrabold tracking-tighter text-white">Find your program</h2>
        <p class="mt-4 text-lg text-gray-400">Filter by level and goal to find the plan that fits you.</p>
      </div>

      <!-- Filter Controls -->
      <div class="flex flex-col gap-4 mb-10" data-workout-filters>
        <div class="flex flex-wrap justify-center gap-2" data-filter-group="category">
          <button class="filter-btn active" data-filter="all">All Levels</button>
          {
            (Object.keys(CATEGORIES) as Category[]).map((key) => (
              <button class="filter-btn" data-filter={key} id={CATEGORIES[key].slug}>
                {CATEGORIES[key].label}
              </button>
            ))
          }
        </div>
        <div class="flex flex-wrap justify-center gap-2" data-filter-group="goal">
          <button class="filter-btn active" data-filter="all">All Goals</button>
          {
            (Object.keys(GOALS) as Goal[]).map((key) => (
              <button class="filter-btn" data-filter={key} id={GOALS[key].slug}>
                {GOALS[key].label}
              </button>
            ))
          }
        </div>
      </div>

      <!-- Workout Grid -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" data-workout-grid>
        {WORKOUTS.map((workout) => <WorkoutCard workout={workout} data-category={workout.category} data-goals={workout.goals.join(',')} />)}
      </div>

      <p class="hidden text-center text-gray-500 mt-12" data-no-results>No workouts match your filters.</p>
    </div>
  </section>

  <!-- Call To Action **************** -->

  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1517836357463-d25dfe029c38?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80"
        alt="Gym"
        class="w-full h-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-black/80"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 md:px-6 py-20 md:py-32 text-center">
      <h2 class="text-4xl md:text-6xl font-extrabold tracking-tighter text-white intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
        Your only limit is <span class="text-red-500">you</span>.
      </h2>
      <p class="mt-4 text-lg md:text-xl text-gray-300 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
        Stop searching for the perfect plan. Pick one. Start today. Show up every day.
      </p>
      <a
        href="#workouts"
        class="mt-8 btn-primary font-semibold inline-flex items-center justify-center gap-2 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
      >
        <Icon name="tabler:bolt" class="w-5 h-5" />
        Browse All Plans
      </a>
    </div>
  </section>
</Layout>

<style>
  .filter-btn {
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background-color: #171717;
    color: #9ca3af;
    transition: all 0.2s;
    cursor: pointer;
  }
  .filter-btn:hover {
    color: #fff;
    border-color: rgba(239, 68, 68, 0.4);
  }
  .filter-btn.active {
    background-color: rgb(239 68 68);
    color: #fff;
    border-color: rgb(239 68 68);
  }
</style>

<script>
  const filterGroups = document.querySelectorAll('[data-filter-group]');
  const grid = document.querySelector('[data-workout-grid]');
  const noResults = document.querySelector('[data-no-results]');
  if (!grid || !noResults) {
    /* nothing to do */
  } else {
    const cards = Array.from(grid.querySelectorAll('[data-category]')) as HTMLElement[];

    const state: Record<string, string> = { category: 'all', goal: 'all' };

    const apply = () => {
      let visible = 0;
      cards.forEach((card) => {
        const cat = card.dataset.category || '';
        const goals = (card.dataset.goals || '').split(',');
        const catOk = state.category === 'all' || cat === state.category;
        const goalOk = state.goal === 'all' || goals.includes(state.goal);
        if (catOk && goalOk) {
          card.classList.remove('hidden');
          visible++;
        } else {
          card.classList.add('hidden');
        }
      });
      noResults.classList.toggle('hidden', visible > 0);
    };

    filterGroups.forEach((group) => {
      const groupName = (group as HTMLElement).dataset.filterGroup || '';
      group.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (!target.classList.contains('filter-btn')) return;
        group.querySelectorAll('.filter-btn').forEach((b) => b.classList.remove('active'));
        target.classList.add('active');
        state[groupName] = target.dataset.filter || 'all';
        apply();
      });
    });

    // Handle hash-based deep links to filters
    const hash = window.location.hash.replace('#', '');
    const knownCats = ['beginner', 'intermediate', 'advanced'];
    const knownGoals = ['muscle-gain', 'fat-loss', 'strength', 'ppl'];
    if (knownCats.includes(hash) || knownGoals.includes(hash)) {
      const group = knownCats.includes(hash) ? 'category' : 'goal';
      const btn = document.querySelector(`[data-filter-group="${group}"] [data-filter="${hash}"]`) as HTMLElement | null;
      if (btn) {
        btn.click();
      }
    }
  }
</script>
