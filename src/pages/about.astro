---
import Layout from '~/layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'About IRONPULSE',
};
---

<Layout metadata={metadata}>
  <section class="relative md:-mt-[76px] not-prose overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://images.unsplash.com/photo-1534438327275-aea6d88d1e4d?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80"
        alt="Training"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/80 to-neutral-950"></div>
    </div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6">
      <div class="pt-0 md:pt-[76px] pointer-events-none"></div>
      <div class="py-20 md:py-32">
        <p class="text-red-500 font-bold tracking-widest uppercase text-sm">About Us</p>
        <h1 class="mt-4 text-4xl md:text-6xl font-extrabold tracking-tighter text-white">
          Built by athletes,<br /><span class="text-red-500">for athletes.</span>
        </h1>
        <p class="mt-6 text-lg text-gray-300 max-w-2xl">
          IRONPULSE was created to remove the guesswork from training. We believe everyone deserves access to structured, effective workout plans — no expensive coaching, no fluff, just results.
        </p>
      </div>
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 md:px-6 py-16 md:py-24">
    <div class="grid sm:grid-cols-3 gap-6 mb-16">
      {
        [
          { icon: 'tabler:target', title: 'Our Mission', text: 'Make elite-level training accessible to everyone, everywhere.' },
          { icon: 'tabler:heartbeat', title: 'Our Values', text: 'Hard work, consistency, and honesty — in training and in business.' },
          { icon: 'tabler:trophy', title: 'Our Promise', text: 'Every plan is tested, proven, and built to get you real results.' },
        ].map((v) => (
          <div class="rounded-2xl bg-neutral-900 border border-white/5 p-6 text-center">
            <div class="w-12 h-12 rounded-xl bg-red-600/10 flex items-center justify-center mx-auto mb-4">
              <Icon name={v.icon} class="w-6 h-6 text-red-500" />
            </div>
            <h3 class="text-lg font-bold text-white">{v.title}</h3>
            <p class="mt-2 text-sm text-gray-400">{v.text}</p>
          </div>
        ))
      }
    </div>

    <div class="prose prose-lg dark:prose-invert max-w-none">
      <h2 class="text-white">Why we built IRONPULSE</h2>
      <p class="text-gray-300">
        The fitness industry is full of overpriced programs, contradictory advice, and endless confusion. We cut through the noise. Every plan on IRONPULSE is built on proven training principles: progressive overload, intelligent volume, and consistent effort.
      </p>
      <p class="text-gray-300">
        Whether you're stepping into a gym for the first time or chasing a new personal record, we have a plan for you. Pick your level, choose your goal, and start training today.
      </p>
    </div>

    <div class="mt-12 text-center">
      <a href="/#workouts" class="btn-primary font-semibold inline-flex items-center justify-center gap-2">
        <Icon name="tabler:bolt" class="w-5 h-5" />
        Browse Workout Plans
      </a>
    </div>
  </section>
</Layout>
