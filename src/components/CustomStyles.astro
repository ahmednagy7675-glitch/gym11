<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(239 68 68);
    --aw-color-secondary: rgb(220 38 38);
    --aw-color-accent: rgb(239 68 68);

    --aw-color-text-heading: rgb(255 255 255);
    --aw-color-text-default: rgb(229 231 235);
    --aw-color-text-muted: rgb(148 163 184);
    --aw-color-bg-page: rgb(10 10 10);

    --aw-color-bg-page-dark: rgb(3 3 3);

    ::selection {
      background-color: rgb(239 68 68);
      color: rgb(255 255 255);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(239 68 68);
    --aw-color-secondary: rgb(220 38 38);
    --aw-color-accent: rgb(239 68 68);

    --aw-color-text-heading: rgb(255 255 255);
    --aw-color-text-default: rgb(229 231 235);
    --aw-color-text-muted: rgb(148 163 184);
    --aw-color-bg-page: rgb(10 10 10);

    ::selection {
      background-color: rgb(239 68 68);
      color: rgb(255 255 255);
    }
  }
</style>
